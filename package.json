{
  "name": "adaptform",
  "version": "1.1.6",
  "description": "Library of adaptive forms of validation",
  "keywords": [
    "form",
    "validation",
    "typescript"
  ],
  "author": "ArhiMEN",
  "type": "module",
  "main": "dist/index.mjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.ts"
    },
    "./*": "./dist/*"
  },
  "files": ["dist/**/*"],
  "sideEffects": false,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "vite": "^7.1.1",
    "vite-plugin-dts": "^4.0.0",
    "typescript": "^5.2.2"
  }
}
