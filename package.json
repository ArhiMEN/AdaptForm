{
  "name": "adaptform",
  "version": "2.0.4",
  "description": "Library of adaptive forms of validation",
  "keywords": [
    "form",
    "validation",
    "typescript",
    "pydantic",
    "luxon"
  ],
  "author": {
    "name": "Stanislav Orlov",
    "email": "stasioniks@gmail.com",
    "url": "https://github.com/ArhiMEN"
  },
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./luxon": {
      "types": "./dist/luxon.d.ts",
      "import": "./dist/luxon.mjs",
      "require": "./dist/luxon.cjs"
    }
  },
  "typesVersions": {
    "*": {
      ".": [
        "./dist/index.d.ts"
      ],
      "luxon": [
        "./dist/luxon.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE.md",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ArhiMEN/adaptform.git"
  },
  "bugs": {
    "url": "https://github.com/ArhiMEN/adaptform/issues"
  },
  "homepage": "https://github.com/ArhiMEN/adaptform#readme",
  "engines": {
    "node": ">=16.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsup",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/luxon": "^3.5.0",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^1.6.1",
    "jsdom": "^29.1.1",
    "luxon": "^3.5.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "peerDependencies": {
    "luxon": ">=3.5.0"
  },
  "peerDependenciesMeta": {
    "luxon": {
      "optional": true
    }
  }
}
